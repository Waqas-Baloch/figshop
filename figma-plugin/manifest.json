{
  "name": "Figma To Photoshop",
  "id": "figshop.edit-in-photoshop",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "editorType": ["figma"],
  "documentAccess": "dynamic-page",
  "menu": [
    { "name": "Open panel", "command": "connect" },
    { "name": "Edit selection in Photoshop", "command": "edit" },
    { "name": "Reset edit (re-fetch from Figma)", "command": "reset" }
  ],
  "relaunchButtons": [
    { "command": "edit", "name": "Edit in Photoshop" }
  ],
  "networkAccess": {
    "allowedDomains": ["http://localhost:3900", "ws://localhost:3900"],
    "reasoning": "Connects to the local companion app to send images to Photoshop and receive edits back."
  }
}
